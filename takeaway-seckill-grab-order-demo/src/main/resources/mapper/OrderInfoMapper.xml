<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.takeaway.mapper.OrderInfoMapper">

    <insert id="insert" parameterType="com.example.takeaway.entity.OrderInfo"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_order_info (
            order_no,
            user_id,
            meal_id,
            order_amount,
            status,
            create_time,
            update_time
        ) VALUES (
                     #{orderNo},
                     #{userId},
                     #{mealId},
                     #{orderAmount},
                     #{status},
                     NOW(),
                     NOW()
                 )
    </insert>

    <select id="selectByOrderNo" resultType="com.example.takeaway.entity.OrderInfo">
        SELECT
            id,
            order_no,
            user_id,
            meal_id,
            order_amount,
            status,
            create_time,
            update_time
        FROM t_order_info
        WHERE order_no = #{orderNo}
    </select>
</mapper>