<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qiange.ragdemo.mapper.KnowledgeDocumentMapper">

    <resultMap id="BaseResultMap" type="com.qiange.ragdemo.entity.KnowledgeDocumentEntity">
        <id property="id" column="id"/>
        <result property="docId" column="doc_id"/>
        <result property="title" column="title"/>
        <result property="fileName" column="file_name"/>
        <result property="category" column="category"/>
        <result property="sourcePath" column="source_path"/>
        <result property="status" column="status"/>
        <result property="chunkCount" column="chunk_count"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectByDocumentId" resultMap="BaseResultMap">
        select id,
               doc_id,
               title,
               file_name,
               category,
               source_path,
               status,
               chunk_count,
               created_at,
               updated_at
        from kb_document
        where doc_id = #{documentId}
        limit 1
    </select>

    <insert id="insert" parameterType="com.qiange.ragdemo.entity.KnowledgeDocumentEntity"
            useGeneratedKeys="true" keyProperty="id">
        insert into kb_document (
            doc_id,
            title,
            file_name,
            category,
            source_path,
            status,
            chunk_count
        ) values (
                     #{docId},
                     #{title},
                     #{fileName},
                     #{category},
                     #{sourcePath},
                     #{status},
                     #{chunkCount}
                 )
    </insert>

    <update id="updateStatusAndChunkCount">
        update kb_document
        set status = #{status},
            chunk_count = #{chunkCount},
            updated_at = now()
        where id = #{id}
    </update>

</mapper>
